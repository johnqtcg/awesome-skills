{
  "id": "001_single_module_service",
  "description": "Standard single-module Go service with Makefile and Dockerfile — skill should produce full-parity workflow with make-delegated core gate and docker-build job",
  "scenario_type": "single_module_service",
  "context": {
    "go_mod_count": 1,
    "has_makefile": true,
    "makefile_targets": ["ci", "docker-build"],
    "has_dockerfile": true,
    "has_golangci_lint_config": true,
    "test_types": ["unit"],
    "existing_workflows": []
  },
  "expected_gates": ["Repository Shape Gate", "Local Parity Gate", "Security and Permissions Gate", "Execution Integrity Gate"],
  "expected_output_fields": ["repository shape classification", "job list", "execution path for each job", "trigger configuration", "permissions", "tool versions", "validation performed"],
  "expected_shape": "single-module application",
  "expected_parity_level": "full",
  "expected_jobs": ["ci", "docker-build"],
  "expected_execution_paths": {
    "ci": "make target",
    "docker-build": "make target"
  },
  "skill_rules_that_must_fire": [
    "Repository Shape Gate",
    "Local Parity Gate",
    "make ci",
    "make docker-build",
    "go-version-file: go.mod",
    "cache: true",
    "permissions",
    "concurrency",
    "cancel-in-progress"
  ]
}
